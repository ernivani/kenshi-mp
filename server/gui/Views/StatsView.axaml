<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KenshiMP.Server.ViewModels"
             x:Class="KenshiMP.Server.Views.StatsView"
             x:DataType="vm:StatsViewModel">
    <Grid RowDefinitions="Auto,*">
        <TextBlock Grid.Row="0" Text="Stats"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <UniformGrid Grid.Row="1" Columns="2" Rows="2">
            <Border Background="#1B1E24" CornerRadius="8" Padding="16" Margin="0,0,8,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Uptime" Foreground="#8A90A0" FontSize="11"/>
                    <TextBlock Text="{Binding Uptime}" Foreground="#E6E8EB" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="#1B1E24" CornerRadius="8" Padding="16" Margin="8,0,0,8">
                <StackPanel Spacing="4">
                    <TextBlock Text="Players" Foreground="#8A90A0" FontSize="11"/>
                    <TextBlock Text="{Binding Players}" Foreground="#E6E8EB" FontSize="24" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="#1B1E24" CornerRadius="8" Padding="16" Margin="0,8,8,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Packets in / out" Foreground="#8A90A0" FontSize="11"/>
                    <TextBlock Text="{Binding PacketsInOut}" Foreground="#E6E8EB" FontSize="22" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
            <Border Background="#1B1E24" CornerRadius="8" Padding="16" Margin="8,8,0,0">
                <StackPanel Spacing="4">
                    <TextBlock Text="Bytes in / out" Foreground="#8A90A0" FontSize="11"/>
                    <TextBlock Text="{Binding BytesInOut}" Foreground="#E6E8EB" FontSize="22" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </UniformGrid>
    </Grid>
</UserControl>
