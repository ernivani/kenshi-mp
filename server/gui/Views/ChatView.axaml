<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KenshiMP.Server.ViewModels"
             x:Class="KenshiMP.Server.Views.ChatView"
             x:DataType="vm:ChatViewModel">
    <Grid RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0" Text="Chat"
                   FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

        <Border Grid.Row="1" Background="#1B1E24" CornerRadius="6" Padding="8">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Entries}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ChatEntry">
                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2">
                                <TextBlock Text="{Binding Time}"   Foreground="#55A" Width="70" FontFamily="Consolas"/>
                                <TextBlock Text="{Binding Author}" Foreground="#7CC4FF" FontWeight="SemiBold"/>
                                <TextBlock Text=":" Foreground="#888"/>
                                <TextBlock Text="{Binding Text}" Foreground="#E6E8EB" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="0,8,0,0">
            <TextBox Grid.Column="0"
                     Text="{Binding Input, Mode=TwoWay}"
                     Watermark="Type a server message..."/>
            <Button Grid.Column="1" Content="Send" Margin="8,0,0,0"
                    Command="{Binding SendCommand}"/>
        </Grid>
    </Grid>
</UserControl>
