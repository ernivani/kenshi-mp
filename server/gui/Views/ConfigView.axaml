<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KenshiMP.Server.ViewModels"
             x:Class="KenshiMP.Server.Views.ConfigView"
             x:DataType="vm:ConfigViewModel">
    <ScrollViewer>
        <StackPanel Spacing="12" MaxWidth="500" HorizontalAlignment="Left">
            <TextBlock Text="Configuration"
                       FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Port (restart to apply)" Foreground="#8A90A0" FontSize="11"/>
                <TextBox Text="{Binding Port, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Max players" Foreground="#8A90A0" FontSize="11"/>
                <NumericUpDown Value="{Binding MaxPlayers, Mode=TwoWay}" Minimum="1" Maximum="256"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Server name" Foreground="#8A90A0" FontSize="11"/>
                <TextBox Text="{Binding ServerName, Mode=TwoWay}"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="View distance" Foreground="#8A90A0" FontSize="11"/>
                <NumericUpDown Value="{Binding ViewDistance, Mode=TwoWay}" Increment="100"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="Save" Command="{Binding SaveCommand}"/>
                <TextBlock Text="{Binding Status}" Foreground="#5FD196" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
